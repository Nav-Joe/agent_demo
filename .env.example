# Tavily API Key（必填）
# 获取地址：https://tavily.com
TAVILY_API_KEY=tvly-xxxxx

# Gradio 服务端口（可选，默认 7860）
PORT=7860

# Ollama 服务地址
# 本地直接运行：http://localhost:11434
# Docker 容器内访问宿主机：http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# Ollama 模型名称（可选，默认 qwen2.5:3b）
OLLAMA_MODEL=qwen2.5:3b

# 主动对话沉默阈值（分钟，默认 3）
PROACTIVE_SILENCE_MINUTES=3

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
